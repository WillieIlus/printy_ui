# =============================================================================
# API base URL — single source of truth for backend server root (no trailing slash)
# =============================================================================
# Only NUXT_PUBLIC_API_BASE_URL is needed. /api and /media paths are appended at runtime.
# This env var is read at RUNTIME (not baked at build time), so the same build artifact
# can be promoted from staging to production just by changing this variable.

# LOCAL dev: frontend localhost:3000 → backend localhost:8000
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000

# PRODUCTION (DigitalOcean App Platform / Netlify / any SSR host):
#   Set NUXT_PUBLIC_API_BASE_URL in your App Platform environment variables UI.
#   Example: NUXT_PUBLIC_API_BASE_URL=https://api.printy.ke
#
# DigitalOcean App Platform notes:
#   - Set env vars under App Settings > App-Level Environment Variables
#   - Scope: RUN_AND_BUILD_TIME (required so Nuxt can read it on server start)
#   - No trailing slash on the URL
#   - The app will be built once; the runtime env var controls which backend it hits

# =============================================================================
# Site URL (used for SEO/sitemap generation)
# =============================================================================
# NUXT_PUBLIC_SITE_URL=https://www.printy.ke

# =============================================================================
# Nitro preset — controls the server output format
# =============================================================================
# Nuxt auto-detects Netlify in deploy builds, so no preset override is normally needed.
# For DigitalOcean App Platform (Node.js server), leave unset — Nuxt defaults to node-server.
# SERVER_PRESET=

# =============================================================================
# SEO indexing
# =============================================================================
# Set to 'production' only in the live deploy to allow search indexing.
# Leave unset in staging/dev to prevent accidental indexing.
# NUXT_SITE_ENV=production

# =============================================================================
# Google Maps API — for location search and map preview in shop form
# =============================================================================
# Enable Places Autocomplete and map in the Location section. Without this key
# the form falls back to manual address entry.
# NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key
