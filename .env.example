# =============================================================================
# API base URL – single source of truth for backend server root (no trailing slash)
# =============================================================================
# Set NUXT_PUBLIC_API_BASE_URL. apiBase and mediaBase are derived automatically.

# --- LOCAL: frontend localhost:3000 -> backend localhost:8000 ---
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- PRODUCTION (Netlify / printy.ke): frontend -> PythonAnywhere backend ---
# When deploying to Netlify, set this in Site settings > Environment variables:
#   NUXT_PUBLIC_API_BASE_URL=https://amazingace00.pythonanywhere.com
#
# Uncomment and use for local builds that target production API:
# NUXT_PUBLIC_API_BASE_URL=https://amazingace00.pythonanywhere.com

# =============================================================================
# Google Maps API – for location search and map preview in shop form
# =============================================================================
# Enable Places Autocomplete and map in Location section. Without this key,
# the form falls back to manual address entry.
# NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
