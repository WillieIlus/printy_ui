# Single source of truth for the backend server root.
# Do not include /api or a trailing slash - the app derives /api and /media at runtime.
NUXT_PUBLIC_API_BASE_URL=https://api.printy.ke
NUXT_PUBLIC_SITE_URL=https://printy.ke
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Production examples:
# NUXT_PUBLIC_API_BASE_URL=https://api.printy.ke
# NUXT_PUBLIC_SITE_URL=https://printy.ke

# Optional SEO indexing flag for the live deploy only:
# NUXT_SITE_ENV=production
