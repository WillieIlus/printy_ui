# Single source of truth for the frontend API base.
# Include /api and omit a trailing slash.
NUXT_PUBLIC_API_BASE=http://localhost:8000/api
NUXT_PUBLIC_SITE_URL=https://printy.ke
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Production examples:
# NUXT_PUBLIC_API_BASE=https://api.printy.ke/api
# NUXT_PUBLIC_SITE_URL=https://printy.ke

# Optional SEO indexing flag for the live deploy only:
# NUXT_SITE_ENV=production
